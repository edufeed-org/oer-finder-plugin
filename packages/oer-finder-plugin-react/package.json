{
  "name": "@edufeed-org/oer-finder-plugin-react",
  "version": "0.3.2",
  "description": "React components for OER Finder Plugin",
  "author": "B310 Digital GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edufeed-org/oer-finder-plugin.git",
    "directory": "packages/oer-finder-plugin-react"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:plugin": "pnpm --filter @edufeed-org/oer-finder-plugin build",
    "build": "pnpm run build:plugin && vite build && tsc --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "peerDependencies": {
    "@edufeed-org/oer-finder-plugin": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lit/react": "^1.0.8",
    "@types/react": "^19.2.14",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "rollup": "^4.60.0",
    "rollup-plugin-license": "^3.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
