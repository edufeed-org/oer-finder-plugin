{
  "name": "@edufeed-org/oer-proxy",
  "version": "0.0.1",
  "description": "Nostr OER Proxy and Plugin",
  "author": "B310 Digital GmbH",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:adapters": "pnpm --filter '@edufeed-org/oer-adapter-*' build",
    "build:packages": "pnpm run build:adapters",
    "build": "pnpm run build:packages && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run start:prod",
    "start:dev": "pnpm run build:packages && rm -f tsconfig.tsbuildinfo && nest start --watch",
    "start:dev:plugin-example": "pnpm --filter '@edufeed-org/oer-finder-plugin-example' run dev --host",
    "start:debug": "pnpm run build:packages && nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "pnpm run build:packages && tsc --noEmit",
    "test": "pnpm run build:packages && NODE_ENV=test jest",
    "test:watch": "pnpm run build:packages && NODE_ENV=test jest --watch",
    "test:cov": "pnpm run build:packages && NODE_ENV=test jest --coverage",
    "test:debug": "pnpm run build:packages && NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "pnpm run build:packages && NODE_ENV=test jest --config ./test/jest-e2e.json --runInBand",
    "generate:openapi": "ts-node scripts/generate-openapi-spec.ts"
  },
  "dependencies": {
    "@edufeed-org/oer-adapter-arasaac": "workspace:*",
    "@edufeed-org/oer-adapter-core": "workspace:*",
    "@edufeed-org/oer-adapter-nostr-amb-relay": "workspace:*",
    "@edufeed-org/oer-adapter-openverse": "workspace:*",
    "@edufeed-org/oer-adapter-rpi-virtuell": "workspace:*",
    "@edufeed-org/oer-adapter-wikimedia": "workspace:*",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "helmet": "^8.1.0",
    "swagger-ui-express": "^5.0.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!.*(@noble|@scure|nostr-tools|nostr-wasm)/)"
    ]
  },
  "pnpm": {
    "overrides": {
      "rollup": "^4.59.0",
      "flatted": "^3.4.2",
      "@angular-devkit/core>ajv": "^8.18.0"
    }
  }
}
